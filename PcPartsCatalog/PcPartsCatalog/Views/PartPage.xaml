<?xml version="1.0" encoding="utf-8" ?>

<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="PcPartsCatalog.Views.PartPage"
    Title="Комплектующее">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="15">
            <Entry x:Name="NameEntry" Placeholder="Название" />
            <Entry x:Name="CategoryEntry" Placeholder="Категория" />
            <Entry x:Name="ManufacturerEntry" Placeholder="Производитель" />
            <Entry x:Name="PriceEntry" Placeholder="Цена" Keyboard="Numeric" />
            <Editor x:Name="DescriptionEditor" Placeholder="Описание" HeightRequest="120" />

            <Button Text="Сохранить" Clicked="OnSaveClicked" />
            <Button Text="Удалить" BackgroundColor="Red" TextColor="White" Clicked="OnDeleteClicked" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>