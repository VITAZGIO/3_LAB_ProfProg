<?xml version="1.0" encoding="utf-8" ?>

<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="PcPartsCatalog.MainPage"
    Title="Каталог комплектующих ПК">

    <VerticalStackLayout Padding="20" Spacing="15">

        <Label
            Text="Каталог комплектующих ПК"
            FontSize="24"
            FontAttributes="Bold"
            HorizontalOptions="Center" />

        <Button
            Text="Добавить комплектующее"
            Clicked="OnAddClicked" />

        <Button
            Text="Загрузить демо-данные из API"
            Clicked="OnLoadFromApiClicked" />

        <Button
            Text="Удалить все"
            BackgroundColor="DarkRed"
            TextColor="White"
            Clicked="OnDeleteAllClicked" />

        <CollectionView
            x:Name="PartsCollection"
            SelectionMode="Single"
            SelectionChanged="OnPartSelected">

            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame Margin="0,5" Padding="12" BorderColor="Gray">
                        <VerticalStackLayout>
                            <Label Text="{Binding Name}" FontSize="18" FontAttributes="Bold" />
                            <Label Text="{Binding Category}" />
                            <Label Text="{Binding Manufacturer}" />
                            <Label Text="{Binding Price, StringFormat='Цена: {0} руб.'}" />
                        </VerticalStackLayout>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>

        </CollectionView>

    </VerticalStackLayout>

</ContentPage>